#!/usr/bin/env bash
# .suede/upstream — ships INSIDE a suede dependency:
#     <repo>/dependencies/<dep>/.suede/upstream
#
# Running it proposes THIS dependency's local changes to the library upstream,
# as a reviewable PR against the library's `main`:
#     ./dependencies/<dep>/.suede/upstream      (if executable)
#     bash dependencies/<dep>/.suede/upstream
#
# Thin bootstrapper: the real logic is hosted so it can evolve without
# re-shipping dependencies. It locates the dependency root (the nearest ancestor
# holding a .gitrepo) and hands it to the hosted script. Override the host for
# forks/testing with SUEDE_UPSTREAM_URL.

set -euo pipefail

err() { echo "error: $*" >&2; exit 1; }

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)" \
  || err "cannot resolve script location"

# Walk up to the dependency root (folder containing .gitrepo). Works whether
# this lives at <dep>/.suede/upstream or directly at <dep>/upstream.
DEP_DIR="$SELF_DIR"
while [ "$DEP_DIR" != "/" ] && [ ! -f "$DEP_DIR/.gitrepo" ]; do
  DEP_DIR="$(dirname "$DEP_DIR")"
done
[ -f "$DEP_DIR/.gitrepo" ] \
  || err "no .gitrepo found above $SELF_DIR — is this inside a vendored suede dependency?"

command -v curl >/dev/null || err "curl not found"
HOST="${SUEDE_UPSTREAM_URL:-https://suede.sh/upstream}"

exec bash <(curl -fsSL "$HOST") "$DEP_DIR" "$@"
